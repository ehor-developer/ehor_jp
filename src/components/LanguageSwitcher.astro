---
import { getLangFromUrl } from '../i18n/utils';
import { languages } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname.replace(/^\/[a-z]{2}/, '') || '/';
---

<div class="relative inline-block">
  <button 
    id="language-toggle" 
    class="rounded-full text-stone py-2 px-3 inline-flex items-center gap-2 hover:bg-gray-100 transition-all duration-200 ease-in-out"
    aria-label="言語を選択"
  >
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      class="w-5 h-5" 
      fill="none" 
      viewBox="0 0 24 24" 
      stroke="currentColor" 
      stroke-width="2"
    >
      <path 
        stroke-linecap="round" 
        stroke-linejoin="round" 
        d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
      />
    </svg>
    <span class="text-sm font-medium">{languages[lang]?.englishName || 'Japanese'}</span>
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      class="w-3 h-3 transition-transform duration-200" 
      id="dropdown-arrow"
      fill="none" 
      viewBox="0 0 24 24" 
      stroke="currentColor" 
      stroke-width="2"
    >
      <path 
        stroke-linecap="round" 
        stroke-linejoin="round" 
        d="M19 9l-7 7-7-7" 
      />
    </svg>
  </button>
  
  <div 
    id="language-dropdown" 
    class="absolute right-0 top-full mt-2 py-2 w-44 bg-white border rounded-lg z-50 hidden opacity-0 scale-95 transform transition-all duration-200 ease-out"
  >
    {Object.entries(languages).map(([code, langData]) => {
      const href = code === 'ja' ? currentPath : `/${code}${currentPath}`;
      const isActive = lang === code;
      
      return (
        <a
          href={href}
          class={`flex items-center justify-between px-4 py-3 text-sm hover:bg-gray-100 transition-colors duration-150 ${
            isActive ? 'bg-gray-100 font-medium' : ''
          }`}
        >
          <div class="flex flex-col gap-0.5">
            <span class="font-medium text-gray-900">{langData.name}</span>
            <span class="text-xs text-gray-500">{langData.englishName}</span>
          </div>
          {isActive && (
            <svg 
              xmlns="http://www.w3.org/2000/svg" 
              class="w-4 h-4 text-green-600" 
              fill="none" 
              viewBox="0 0 24 24" 
              stroke="currentColor" 
              stroke-width="2"
            >
              <path 
                stroke-linecap="round" 
                stroke-linejoin="round" 
                d="M5 13l4 4L19 7" 
              />
            </svg>
          )}
        </a>
      );
    })}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('language-toggle');
    const dropdown = document.getElementById('language-dropdown');
    const arrow = document.getElementById('dropdown-arrow');
    if (toggle && dropdown && arrow) {
      let isOpen = false;
      toggle.addEventListener('click', (e) => {
        e.stopPropagation();
        if (isOpen) {
         
          dropdown.classList.remove('opacity-100', 'scale-100');
          dropdown.classList.add('opacity-0', 'scale-95');
          arrow.style.transform = 'rotate(0deg)';
          setTimeout(() => {
            dropdown.classList.add('hidden');
          }, 200);
        } else {
         
          dropdown.classList.remove('hidden');
          arrow.style.transform = 'rotate(180deg)';
          setTimeout(() => {
            dropdown.classList.remove('opacity-0', 'scale-95');
            dropdown.classList.add('opacity-100', 'scale-100');
          }, 10);
        }
        
        isOpen = !isOpen;
      });
      document.addEventListener('click', (e) => {
        if (!toggle.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
          if (isOpen) {
            dropdown.classList.remove('opacity-100', 'scale-100');
            dropdown.classList.add('opacity-0', 'scale-95');
            arrow.style.transform = 'rotate(0deg)';
            setTimeout(() => {
              dropdown.classList.add('hidden');
            }, 200);
            isOpen = false;
          }
        }
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen) {
          dropdown.classList.remove('opacity-100', 'scale-100');
          dropdown.classList.add('opacity-0', 'scale-95');
          arrow.style.transform = 'rotate(0deg)';
          setTimeout(() => {
            dropdown.classList.add('hidden');
          }, 200);
          isOpen = false;
        }
      });
    }
  });
</script>