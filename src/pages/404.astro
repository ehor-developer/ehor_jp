---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const homeUrl = lang === 'ja' ? '/' : `/${lang}/`;
---

<Layout title={t("404.title")} description={t("404.description")}>
    <div class="min-h-screen flex items-center justify-center px-4">
        <div class="text-center">
            <h1 class="text-8xl font-bold text-gray-300 mb-6">404</h1>
            <h2 class="text-2xl font-bold text-gray-800 mb-8">
                {t("404.heading")}
            </h2>

            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <a
                    href={homeUrl}
                    class="px-6 py-3 text-white bg-gray-800 hover:bg-gray-700 rounded-md transition-colors duration-200"
                >
                    {t("404.home")}
                </a>
            </div>
        </div>
    </div>
</Layout>
