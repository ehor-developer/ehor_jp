---
// このページは直接アクセス時にリダイレクト用として使用
// メニューモーダルが自動で起動する
---

<script>
  // クライアントサイドでのリダイレクト（モーダル起動フラグ付き）
  if (typeof window !== 'undefined') {
    // sessionStorageにモーダル起動フラグを設定
    sessionStorage.setItem('showMenuModal', 'true');
    // URLパラメータでもフラグを設定
    window.location.replace('/?menu=open');
  }
</script>

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Redirecting...</title>
  <style>
    body {
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
      font-family: system-ui, sans-serif;
      background-color: #f9fafb;
    }
    .loading {
      text-align: center;
    }
    .spinner {
      border: 3px solid #f3f4f6;
      border-radius: 50%;
      border-top: 3px solid #3b82f6;
      width: 30px;
      height: 30px;
      animation: spin 1s linear infinite;
      margin: 0 auto 16px;
    }
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
  </style>
</head>
<body>
  <div class="loading">
    <div class="spinner"></div>
    <p>メニューを開いています...</p>
  </div>
</body>
</html>
